# 必填：至少 16 位随机字符串（启动时校验）
# 别名：JWT_SECRET_KEY（二选一）
JWT_SECRET=change-me-to-a-long-random-string-at-least-16-chars

# 推荐：独立密钥用于 RegisteredModel/ModelSetting.api_key 的 Fernet 加密（勿与 JWT 混用）
# 未设置时回退 JWT_SECRET（仅开发便利；生产请显式配置）
# API_KEY_ENCRYPT_SECRET=

# development | production
APP_ENV=development

# 逗号分隔；留空则使用本地开发默认端口（含 8173）
# CORS_ORIGINS=https://your-domain.com

# 数据库（生产推荐 PostgreSQL）
DATABASE_URL=sqlite:///./aistudio.db
# DATABASE_URL=postgresql+psycopg2://aistudio:password@postgres:5432/aistudio

DASHSCOPE_API_KEY=

# 可选：部分模型兜底 Key（Settings.deepseek_api_key）
# DEEPSEEK_API_KEY=

# Agent 默认文本模型 id（未走 Admin llm_router 注册模型时的 fallback）
# AGENT_MODEL=deepseek-v3

# ComfyUI 内网地址（SaaS 部署时仅 backend 可访问，勿暴露公网）
COMFYUI_URL=http://127.0.0.1:8000
COMFYUI_NODES=http://127.0.0.1:8000,http://127.0.0.1:8001
# WebSocket 地址（可选；留空则从 COMFYUI_URL 自动推导 ws://host/ws）
# COMFYUI_WS_URL=ws://127.0.0.1:8000/ws

# 即梦图像 API（仅 jimeng-5.0-lite 模型需要；走百炼/火山引擎申请）
# JIMENG_API_KEY=

# Seedance 2.0（火山方舟 Ark；无 Key 时 registry 保持 enabled=False）
# SEEDANCE_API_KEY=
# SEEDANCE_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# SEEDANCE_MODEL_ID=doubao-seedance-2-0-260128

# 限流与并发（可按套餐调整）
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_USER_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=30
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15
AGENT_RATE_LIMIT_USER_PER_MINUTE=20
GENERATION_MAX_CONCURRENT=3
# 团队级生成并发上限（generation_slots.py；4 人内测建议 8，默认 10）
GENERATION_MAX_CONCURRENT_TEAM=10
MEDIA_TOKEN_TTL_SECONDS=14400

# 协作编辑锁（秒）
# CANVAS_LOCK_TTL_SECONDS=90
# CANVAS_HEARTBEAT_SECONDS=25

# Uvicorn 访问日志：throttle（默认）| off
# UVICORN_ACCESS_LOG=off

# 开发种子账号密码（仅 APP_ENV=development 时 init_db 使用；生产不执行 seed）
# 本地探针默认账号见 HANDOFF；勿将生产密码写入仓库
SEED_ADMIN_PASSWORD=
SEED_TESTUSER_PASSWORD=
SEED_TESTUSER2_PASSWORD=

# 注册邀请码（非空时 /api/auth/register 必须提交匹配的 invite_code）
REGISTRATION_INVITE_CODE=LJL888888

# Redis（顶号锁 / 限流 / 生成并发 / WS 多实例广播）
# 若 redis.conf 设置了 requirepass，URL 需带密码：
# REDIS_URL=redis://:你的密码@127.0.0.1:6379/0
REDIS_URL=redis://127.0.0.1:6379/0

# Mock 出图/视频（ComfyUI 未就绪时跑通端到端测试；默认 false）
# AGENT_MOCK_GENERATION=true
# AGENT_MOCK_FAILURE_RATE=0.1

# Agent LLM 重试（网络抖动/限流时指数退避，默认 3 次、间隔 1s 起）
# AGENT_LLM_MAX_RETRIES=3
# AGENT_LLM_RETRY_BASE_DELAY=1.0

# 探针专用（本地 scripts/_paste_script_checklist_probe.py 等，生产勿设）
# API_BASE=http://127.0.0.1:7788
# PROBE_USER=admin
# PROBE_PASSWORD=

# Cloudflare R2（团队文件空间；S3 兼容）
# Endpoint: https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=seele
# R2 bucket 公开访问域名（无尾斜杠）；add-to-assets 依赖此项
# 例：https://pub-xxxx.r2.dev （Public Development URL）
R2_PUBLIC_URL=
